# Copiar a .env.local y completar. NUNCA commitear .env.local (está en .gitignore).

# LiveKit Cloud → Project Settings → Keys
LIVEKIT_URL=wss://TU-PROYECTO.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI (Realtime API)
OPENAI_API_KEY=

# Tool-backend GAS: URL /exec del deployment dedicado "Cualquiera" + el secreto de Script Properties
GAS_VOZ_URL=https://script.google.com/macros/s/AKfy.../exec
VOZ_TOOL_SECRET=
